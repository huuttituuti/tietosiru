---
// src/components/Card.astro
interface Props {
  heading: string;
  text: string;
  link: string;
}

const { heading, text, link } = Astro.props;
---

<a
  href={link}
  class="p-7 border-1 border-border hover:border-accent transition-colors duration-300 cursor-pointer"
>
  <h3 class="text-[1.25rem] font-normal mb-2">{heading}</h3>
  <p class="text-gray text-[1rem] max-w-[80%] leading-relaxed">
    {text}
  </p>
</a>
