---
import { Image } from "astro:assets";
import logo from "../assets/logo-white.svg";
import posti from "../assets/posti-white.png";
---

<footer class="bg-main text-white">
  <div class="p-3">
    <div
      class="max-w-[1300px] w-[100%] ml-auto mr-auto flex flex-row justify-between items-stretch"
    >
      <div class="">
        <Image width="170" src={logo} alt="Tietosiru logo" />
      </div>
      <div class="flex flex-row items-center space-x-10">
        <div class="flex flex-row space-x-1">
          <p class="font-normal">Puhelin:</p>
          <a class="pl-1" href="tel:0452384114">045 238 4114</a>
        </div>
        <div class="flex flex-row items-center space-x-2">
          <p class="font-normal">e-mail:</p>
          <Image width="125" src={posti} alt="Sähköpostiosoite" />
        </div>
      </div>
    </div>
  </div>
  <div class="bg-light text-black">
    <div
      class="max-w-[1300px] w-[100%] ml-auto mr-auto p-2 flex flex-row justify-center items-center"
    >
      <p>
        © {new Date().getFullYear()} Tietosiru - Forensic Electrical Investigation
      </p>
    </div>
  </div>
</footer>
