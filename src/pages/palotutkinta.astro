---
import Layout from "../layouts/Layout.astro";
import CardProcess from "../components/CardProcess.astro";
import { Image } from "astro:assets";
import heroImage from "../assets/tietosiru-kuva-1.webp";

// Welcome to Astro! Wondering what to do next? Check out the Astro documentation at https://docs.astro.build
// Don't want to use any of this? Delete everything in this file, the `assets`, `components`, and `layouts` directories, and start fresh.
---

<Layout>
  <main>
    <div class="h-[80px] bg-light"></div>
    <section class="bg-white border-t-1 border-b-1 border-border">
      <div class="max-w-[1400px] w-[100%] ml-auto mr-auto p-10 pb-15">
        <div class="flex flex-row space-y-10 justify-between">
          <div class="max-w-[700px]">
            <h1 class="flex flex-col text-[2.5rem]">
              <span
                class="text-accent font-light text-[1.15rem] tracking-[2px] uppercase"
                >Service</span
              >Fire Investigation
            </h1>
            <p class="text-gray mt-5">
              Tietosiru Oy has expertise in an area of forensic electrical
              investigation. Usually we act in a team of investigators from
              several areas of expertise.
            </p>
          </div>
          <div class="border-l-1 border-border pl-10">
            <h2 class="uppercase tracking-[2px] mb-3">Scope</h2>
            <ul class="text-gray flex flex-col space-y-2 list-disc list-inside">
              <li>Fire scene investigation</li>
              <li>Electrical fault analysis</li>
              <li>Fire origin determination</li>
              <li>Post-fire safety assessments</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-white p-6 pb-0">
      <div class="max-w-[1400px] w-[100%] ml-auto mr-auto p-10 pb-5">
        <h2 class="text-[1.25rem] font-medium tracking-[1.5px] uppercase">
          Investigation Process
        </h2>
        <p class="mt-4 max-w-[60%] text-gray">
          Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do
          eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad
          minim veniam, quis nostrud exercitation ullamco laboris nisi ut
          aliquip ex ea commodo consequat. Duis aute irure dolor in
          reprehenderit in voluptate velit.
        </p>
      </div>

      <div class="pb-6">
        <div
          class="max-w-[1400px] mr-auto ml-auto w-[100%] p-10 flex-row flex justify-center items-start space-x-10"
        >
          <CardProcess
            heading="Initial Assessment"
            text="Our team conducts a thorough initial assessment of the fire scene, gathering evidence and documenting the surroundings."
          />
          <CardProcess
            heading="Electrical Analysis"
            text="We analyze electrical components and systems to identify potential causes of the fire, such as short circuits or faulty wiring."
          />
          <CardProcess
            heading="Fire Origin Determination"
            text="Using our expertise, we determine the origin of the fire and assess contributing factors to understand how it started."
          />
        </div>
      </div>
    </section>

    <section class="bg-white p-10 pt-0 pb-0">
      <div class="max-w-[1400px] w-[100%] ml-auto mr-auto p-5 pb-15">
        <div class="bg-dark p-15 rounded-md text-white">
          <h2 class="text-[1.15rem] font-normal tracking-[1.5px]">
            Technical documentation
          </h2>
          <p class="mt-4">
            After the investigation, we compile a comprehensive report detailing
            our findings, analysis, and conclusions. This documentation is
            crucial for legal proceedings and insurance claims.
          </p>
        </div>
      </div>

