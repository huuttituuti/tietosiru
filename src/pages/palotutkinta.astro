    <section>
      <div class="max-w-[1400px] w-[100%] ml-auto mr-auto p-10 pb-15 pt-10">
        <h2
          class="text-[1.5rem] font-medium tracking-[1.5px] uppercase mb-10 border-b-1 border-gray-300 pb-2"
