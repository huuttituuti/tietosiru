---
import Welcome from "../components/Welcome.astro";
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import heroImage from "../assets/tietosiru-kuva-1.webp";
import { navLinks } from "../data/navData.json";
import CardCoreServices from "../components/CardCoreServices.astro";

// Welcome to Astro! Wondering what to do next? Check out the Astro documentation at https://docs.astro.build
// Don't want to use any of this? Delete everything in this file, the `assets`, `components`, and `layouts` directories, and start fresh.
---

<Layout>
  <main>
    <section class="h-[500px] bg-light">
      <div class="w-[100%] h-[100%] flex flex-row justify-center">
        <div
          class="self-center flex flex-row justify-between items-center space-x-10"
        >
          <div class="max-w-[700px] w-[100%] p-10">
            <h1 class="text-[2.6rem] mb-[25px] text-dark leading-[1.2]">
              Independent expertise in <span class="text-accent font-medium"
                >forensic electrical investigation</span
              > and fire origin analysis.
            </h1>
            <p class="max-w-[500px] text-gray">
              Provident cupiditate voluptatem et in. Quaerat fugiat ut assumenda
              excepturi exercitationem quasi. In deleniti eaque aut repudiandae
              et a id nisi.
            </p>
            <button
              class="p-2.5 pl-7 pr-7 mt-6 bg-dark text-white cursor-pointer"
            >
              Request Consultation
            </button>
          </div>
          <Image src={heroImage} width="450" alt="Teksti" class="rounded-sm" />
        </div>
      </div>
    </section>

    <section
      class="w-[100%] ml-auto mr-auto p-10 pb-15 bg-white border-t-1 border-border"
    >
      <div class="max-w-[1400px] mr-auto ml-auto w-[100%] p-10 space-y-10">
        <h2 class="font-semibold text-[1.1rem] tracking-[2px]">
          CORE SERVICES
        </h2>
        <grid
          class="grid-cols-3 grid-flow-row auto-rows-auto gap-y-10 gap-x-10 grid"
        >
          <CardCoreServices
            link="/palotutkinta"
            heading="Fire and explosion scene investigation"
            text="Lorem ipsum dolor sit amet, consectetur adipiscing elit."
          />

          <CardCoreServices
            link="/"
            heading="Laboratory investigations"
            text="Lorem ipsum dolor sit amet, consectetur adipiscing elit."
          />
          <CardCoreServices
            link="/"
            heading="Customized trainings"
            text="Lorem ipsum dolor sit amet, consectetur adipiscing elit."
          />
        </grid>
      </div>
    </section>

    <section class="max-w-[1400px] w-[100%] ml-auto mr-auto p-10 pt-25 pb-30">
      <div
        class="flex flex-row justify-between items-center space-x-10 h-[400px]"
      >
        <Image src={heroImage} width="600" alt="Teksti" class="rounded-sm" />
        <div>
          <h2 class="text-[1.5rem] font-semibold mb-4">About Us</h2>
          <p class="text-gray text-[1rem] max-w-[80%] leading-relaxed">
            Provident cupiditate voluptatem et in. Quaerat fugiat ut assumenda
            excepturi exercitationem quasi. In deleniti eaque aut repudiandae et
            a id nisi.
          </p>
        </div>
      </div>
    </section>

    <section class="w-[100%] ml-auto mr-auto p-10 bg-dark text-white">
      <div
        class="max-w-[1400px] flex flex-row justify-between items-stretch self-center ml-auto mr-auto w-[100%] p-5"
      >
        <h2 class="text-[1.15rem]">
          Request technical consultation or expert opinion.
        </h2>
        <button class="p-2.5 pl-7 pr-7 bg-accent text-white cursor-pointer">
          Request Consultation
        </button>
      </div>
    </section>
  </main>
</Layout>
